# ─────────────────────────────────────────────────────────────────────────────
# Medical AI Receptionist — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Medical AI Receptionist"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/v1
AGENT_BACKEND=crewai

# ── LLM PROVIDER ─────────────────────────────────────────────────────────────
# "openai"   → uses OpenAI API (cloud, requires OPENAI_API_KEY)
# "lmstudio" → uses LM Studio local server (no API key needed)
LLM_PROVIDER=openai

# ── OpenAI (cloud) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# STT via OpenAI Whisper
STT_PROVIDER=openai
OPENAI_STT_MODEL=whisper-1
OPENAI_STT_LANGUAGE=en   # or bn, or leave en for Banglish
TTS_PROVIDER=edge
EDGE_TTS_VOICE=en-US-JennyNeural
# ── LM Studio (local) ─────────────────────────────────────────────────────────
# Steps:
#   1. Open LM Studio
#   2. Go to "Search" → download "liquid/lfm2-1.2b"
#   3. Go to "Server" tab → select the model → click "Start Server"
#   4. Default URL: http://localhost:1234/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
#LMSTUDIO_MODEL=liquid/lfm2-1.2b

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=medical_receptionist

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+13023034387
TWILIO_WEBHOOK_BASE_URL=https://uncatastrophically-unrivalled-coreen.ngrok-free.dev

# ── Clinic Info ───────────────────────────────────────────────────────────────
CLINIC_NAME="HealthCare Medical Center"
CLINIC_PHONE=+8801888410789
CLINIC_ADDRESS="123 Medical Street, Dhaka, Bangladesh"
CLINIC_HOURS="Saturday to Thursday, 9 AM to 10 PM"

# ── Reminder ──────────────────────────────────────────────────────────────────
REMINDER_HOURS_BEFORE=5
#TTS_PROVIDER=gtts
GTTS_LANG=en