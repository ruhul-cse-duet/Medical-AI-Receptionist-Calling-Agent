# ─────────────────────────────────────────────────────────────────────────────
# Medical AI Receptionist — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Medical AI Receptionist"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/v1

# ── LLM PROVIDER ─────────────────────────────────────────────────────────────
# "openai"   → uses OpenAI API (cloud, requires OPENAI_API_KEY)
# "lmstudio" → uses LM Studio local server (no API key needed)
LLM_PROVIDER=lmstudio

# Speech Providers
# STT_PROVIDER: none | deepgram | faster_whisper | openai
# TTS_PROVIDER: none | elevenlabs | edge | piper | gtts | coqui
STT_PROVIDER=faster_whisper
TTS_PROVIDER=edge

# ── OpenAI (cloud) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_STT_MODEL=whisper-1
OPENAI_STT_LANGUAGE=en

# ── LM Studio (local) ─────────────────────────────────────────────────────────
# Steps:
#   1. Open LM Studio
#   2. Go to "Search" → download "liquid/lfm2-1.2b"
#   3. Go to "Server" tab → select the model → click "Start Server"
#   4. Default URL: http://localhost:1234/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=liquid/lfm2-1.2b

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=medical_receptionist

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+8801XXXXXXXXX
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io


# Faster-Whisper (local STT)
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
STT_LANGUAGE=en
STT_CHUNK_SECONDS=1
STT_MIN_SILENCE_MS=800


# Edge TTS (local)
EDGE_TTS_VOICE=en-US-JennyNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz
TTS_AUDIO_TTL_SECONDS=600

# gTTS
GTTS_LANG=en

# Coqui TTS
COQUI_TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
COQUI_TTS_USE_GPU=false

# ── Clinic Info ───────────────────────────────────────────────────────────────
CLINIC_NAME="HealthCare Medical Center"
CLINIC_PHONE=+8801XXXXXXXXX
CLINIC_ADDRESS="123 Medical Street, Dhaka, Bangladesh"
CLINIC_HOURS="Saturday to Thursday, 9 AM to 8 PM"

# ── Reminder ──────────────────────────────────────────────────────────────────
REMINDER_HOURS_BEFORE=5
