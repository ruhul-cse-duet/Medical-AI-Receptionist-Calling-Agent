# ─────────────────────────────────────────────────────────────────────────────
# Medical AI Receptionist — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Medical AI Receptionist"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/v1
AGENT_BACKEND=crewai

# ── LLM PROVIDER ─────────────────────────────────────────────────────────────
# "openai"   → uses OpenAI API (cloud, requires OPENAI_API_KEY)
# "lmstudio" → uses LM Studio local server (no API key needed)
LLM_PROVIDER=openai

# ── OpenAI (cloud) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
STT_PROVIDER=openai
OPENAI_STT_MODEL=whisper-1
OPENAI_STT_LANGUAGE=en
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=shimmer

# ── OpenAI Realtime API ────────────────────────────────────────────────────────
# Set USE_REALTIME_API=true to bypass STT + TTS + LLM and replace them with
# a single gpt-4o-realtime-preview WebSocket for ultra-low-latency voice calls.
#
# When enabled:
#   STT_PROVIDER  → ignored (Whisper runs inside OpenAI Realtime)
#   TTS_PROVIDER  → ignored (TTS runs inside OpenAI Realtime)
#   AGENT_BACKEND → ignored (conversation handled by gpt-4o-realtime-preview)
#
# Benefits vs classic pipeline:
#   • ~300 ms end-to-end latency  (vs 1–3 s for STT→LLM→TTS round trips)
#   • Native barge-in             (patient can interrupt AI mid-sentence)
#   • Zero audio conversion       (g711_ulaw passes straight through both ways)
#   • Appointment tools still work via OpenAI function calling
#
USE_REALTIME_API=false
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2025-06-03
# Realtime voice options: alloy | ash | ballad | coral | echo | sage | shimmer | verse
OPENAI_REALTIME_VOICE=shimmer

# ── LM Studio (local) ─────────────────────────────────────────────────────────
# 1. Open LM Studio → Search → download "liquid/lfm2-1.2b"
# 2. Server tab → select model → Start Server  (default: http://localhost:1234/v1)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
#LMSTUDIO_MODEL=liquid/lfm2-1.2b

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=medical_receptionist

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+13023034387
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-domain.ngrok-free.app

# ── Clinic Info ───────────────────────────────────────────────────────────────
CLINIC_NAME="HealthCare Medical Center"
CLINIC_PHONE=+8801888410789
CLINIC_ADDRESS="123 Medical Street, Dhaka, Bangladesh"
CLINIC_HOURS="Saturday to Thursday, 9 AM to 10 PM"

# ── gTTS fallback ─────────────────────────────────────────────────────────────
#TTS_PROVIDER=gtts
GTTS_LANG=en
